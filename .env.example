NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternative fuer neue Supabase-Projekte mit sb_publishable_... Key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BauPro

# Nur serverseitig verwenden. Wird fuer "Mitarbeiter manuell anlegen" benoetigt.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Passwort fuer `npm run seed:demo`.
DEMO_USER_PASSWORD=BauProDemo!2026

# Optional: benoetigt, wenn offizielle Lieferanten-API-Keys gespeichert werden sollen.
# Mindestens 32 Zeichen zufaellig waehlen.
SUPPLIER_API_ENCRYPTION_KEY=

# Optional: OpenAI-KI-Funktionen. Nur serverseitig verwenden, niemals NEXT_PUBLIC.
# Ohne OPENAI_API_KEY bleibt die App voll nutzbar und zeigt KI als nicht konfiguriert.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: Online Price Discovery fuer Chef/Admin.
# Prioritaet in der Kalkulation:
# 1. eigener Firmen-EK, 2. Lieferanten-/CSV-Preislisten, 3. eBay,
# 4. PriceAPI/DataForSEO/SearchApi, 5. Markt-Richtpreis.
# Ohne konfigurierte Quelle zeigt die App sauber "Keine aktuellen Online-Angebote gefunden".
ONLINE_PRICE_RESULT_LIMIT=12
ONLINE_PRICE_COUNTRY=de
ONLINE_PRICE_LANGUAGE_CODE=de
ONLINE_PRICE_LOCATION_NAME=Germany

# CSV-Preislisten, z. B. Wuerth/BTI/Foerch/Baustoffhandel als erlaubter Feed.
ONLINE_PRICE_WUERTH_CATALOG_CSV_URL=
ONLINE_PRICE_WUERTH_CATALOG_CSV_TOKEN=
ONLINE_PRICE_MANUAL_CSV_URL=
ONLINE_PRICE_MANUAL_CSV_TOKEN=

# eBay Browse API.
ONLINE_PRICE_EBAY_BROWSE_TOKEN=
ONLINE_PRICE_EBAY_BROWSE_URL=https://api.ebay.com/buy/browse/v1/item_summary/search
ONLINE_PRICE_EBAY_MARKETPLACE_ID=EBAY_DE

# API-Aggregatoren.
ONLINE_PRICE_PRICEAPI_URL=
ONLINE_PRICE_PRICEAPI_TOKEN=
ONLINE_PRICE_DATAFORSEO_LOGIN=
ONLINE_PRICE_DATAFORSEO_PASSWORD=
ONLINE_PRICE_DATAFORSEO_URL=https://api.dataforseo.com/v3/serp/google/shopping/live/advanced
ONLINE_PRICE_SEARCHAPI_KEY=
ONLINE_PRICE_SEARCHAPI_URL=https://www.searchapi.io/api/v1/search

# Optionaler Markt-Richtpreis-Fallback, wenn keine bessere Quelle Treffer liefert.
# JSON-Array mit Feldern wie name/product_name, price_gross/price, supplier_name.
ONLINE_PRICE_MARKET_REFERENCE_URL=
ONLINE_PRICE_MARKET_REFERENCE_JSON=
